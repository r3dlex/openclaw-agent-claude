# ── OpenClaw Agent Configuration ──
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Required ---

# Your AI provider API key (e.g., Anthropic, OpenAI)
AGENT_API_KEY=sk-ant-XXXXXXXXXXXXXXXXXXXX

# OpenClaw workspace path (absolute path to this repo's root)
OPENCLAW_WORKSPACE=/path/to/openclaw-agent-claude

# --- Optional ---

# AI model to use (default: claude-sonnet-4-20250514)
AGENT_MODEL=claude-sonnet-4-20250514

# Agent name (set during bootstrap, stored in IDENTITY.md)
AGENT_NAME=

# Heartbeat interval in seconds (default: 1800 = 30 min)
HEARTBEAT_INTERVAL=1800

# Timezone for the agent (default: UTC)
AGENT_TIMEZONE=UTC

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info

# --- Channel Tokens (add as needed) ---

# Discord bot token
# DISCORD_BOT_TOKEN=

# Telegram bot token (from @BotFather)
# TELEGRAM_BOT_TOKEN=

# WhatsApp is paired via QR code, no token needed.
