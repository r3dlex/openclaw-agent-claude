# ── Software Factory Environment Variables ──
# Copy to .env and fill in your values: cp .env.example .env
# See: https://docs.openclaw.ai/gateway/configuration-reference

# ── Factory Settings (required) ──

# Shared data directory for tasks.md, PLAN.md, logs, memory
AGENT_DATA_DIR=./data

# Factory API port
FACTORY_PORT=4000

# Factory API authentication token (generate your own)
# FACTORY_API_TOKEN=

# ── Session Defaults ──

# Max concurrent Claude CLI sessions
MAX_SESSIONS=5

# Kill sessions idle longer than this (minutes)
IDLE_TIMEOUT_MINUTES=30

# Default model for sessions
DEFAULT_MODEL=claude-opus-4-20250514

# Default permission mode for sessions
DEFAULT_PERMISSION_MODE=dangerously-skip-permissions

# ── OpenClaw Gateway ──
# OPENCLAW_GATEWAY_PORT=18789

# ── Messaging Channels (enable what you need) ──
# DISCORD_BOT_TOKEN=
# TELEGRAM_BOT_TOKEN=
# SLACK_BOT_TOKEN=
# SLACK_APP_TOKEN=

# ── Optional Services ──
# BRAVE_API_KEY=
# ELEVENLABS_API_KEY=
